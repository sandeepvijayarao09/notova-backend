# ---- Notova backend environment ----
# Copy to `.env` and fill in. Everything has a dev-safe default EXCEPT secrets
# you should set in production. Third-party OAuth creds are optional: when
# absent, the matching integration returns a clear 400 at connect time.

NODE_ENV=development
PORT=8787

# SQLite file path (dev storage). Use an absolute path in production.
DATABASE_URL=./notova.sqlite

# ---- JWT (access + refresh) ----
# MUST be overridden in production with a long random value.
JWT_SECRET=dev-insecure-jwt-secret-change-me
JWT_ISSUER=notova-backend
JWT_AUDIENCE=notova-app
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# ---- OAuth token encryption (AES-256-GCM) ----
# Must decode to exactly 32 bytes (base64 or hex). Generate a fresh one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# The value below is a dev-only key — generate your own for production.
TOKEN_ENCRYPTION_KEY=jOYijXsBm7sqEIKLyz36u4FJd2gIAs69kcHRnANrN9E=

# Public URL of THIS backend (used to build OAuth redirect URIs).
PUBLIC_BASE_URL=http://localhost:8787

# Deep-link scheme the mobile app listens on after OAuth completes.
APP_OAUTH_REDIRECT_SCHEME=notova://oauth

# ---- Third-party OAuth credentials (all optional) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_LOGIN_URL=https://login.salesforce.com

# ---- Billing (stub) ----
BILLING_CHECKOUT_BASE_URL=https://billing.notova.app/checkout
